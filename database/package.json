{
  "name": "@trmp/database",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun tsc --project tsconfig.drizzle.json",
    "build:ci": "bun --bun tsc",
    "db:generate": "bun --bun drizzle-kit generate --config drizzle/database/drizzle.config.js",
    "db:push": "bun --bun drizzle-kit push --config drizzle/database/drizzle.config.js"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
